{
  "name": "afrolingo-api",
  "version": "1.0.0",
  "description": "Afrolingo API is a robust and scalable backend solution specifically developed for Afrolingo.",
  "main": "server.js",
  "engines": {
    "node": ">=14"
  },
  "scripts": {
    "test": "jest --detectOpenHandles",
    "start": "node dist/server.js",
    "dev": "tsx watch ./src/server.ts",
    "dev-prod": "set NODE_ENV=production && nodemon ./src/server.ts",
    "build": "tsc -p .",
    "start:prod": "pm2 start --env production",
    "postinstall": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khomohzie/afrolingo.git"
  },
  "keywords": [
    "afrolingo",
    "africa",
    "language",
    "learning",
    "indigenous",
    "ai"
  ],
  "author": "Daniel Komolafe",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/khomohzie/afrolingo/issues"
  },
  "homepage": "https://github.com/khomohzie/afrolingo#readme",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fft-js": "^0.0.12",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "toobusy-js": "^0.5.1",
    "wavefile": "^11.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/toobusy-js": "^0.5.4",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
